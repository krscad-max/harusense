---
// Lightweight theme toggle (light/dark). Uses localStorage + prefers-color-scheme.
---
<button id="themeToggle" class="themeToggle" type="button" aria-label="테마 전환">
  <span class="themeToggle__label">테마</span>
</button>

<script is:inline>
  (function(){
    const KEY = 'harusense_theme_v3';
    const root = document.documentElement;

    function getPreferred(){
      // 기본은 라이트(밝은 배경). 다크는 사용자가 토글로 선택.
      return 'light';
    }

    function apply(theme){
      root.dataset.theme = theme;
    }

    const saved = localStorage.getItem(KEY);
    apply(saved || getPreferred());

    const btn = document.getElementById('themeToggle');
    if (btn){
      btn.addEventListener('click', () => {
        const current = root.dataset.theme || getPreferred();
        const next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem(KEY, next);
        apply(next);
      });
    }
  })();
</script>
