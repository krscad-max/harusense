---
const { post, variant = 'default' } = Astro.props;
const { data } = post;
const href = `/posts/${post.slug}/`;
const cover = data.coverImage ?? '/images/post-placeholder.webp';
const excerpt = data.description ?? post.body?.slice?.(0, 180);

const classes = ['card'];
if (variant === 'square') classes.push('square');

const tags = data.tags ?? [];
const category = tags.find((t) => ['japan','travel','kitchen','saving','budgeting','organization','routine','english','japanese'].includes(t)) ?? (tags[0] ?? '');
const categoryLabelMap = {
  japan: '일본',
  travel: '여행',
  kitchen: '주방',
  saving: '절약',
  budgeting: '예산',
  organization: '정리',
  routine: '루틴',
  english: '오늘의 영어',
  japanese: '오늘의 일본어',
};
const categoryLabel = categoryLabelMap[category] ?? category;

const body = post.body ?? '';
const readingMinutes = Math.max(1, Math.round(body.replace(/\s+/g, ' ').trim().length / 900)); // rough char-based
---
<article class={classes.join(' ')}>
  <a class="thumb" href={href} aria-label={data.title}>
    <img src={cover} alt="" loading="lazy" />
    {categoryLabel ? <span class="badge">{categoryLabel}</span> : null}
  </a>
  <div class="inner">
    <h3><a href={href} style="text-decoration:none;">{data.title}</a></h3>
    <p>{excerpt}</p>
    <div class="meta">
      <span>{data.date.toLocaleDateString('ko-KR')}</span>
      <span>읽는 시간 {readingMinutes}분</span>
      {tags?.length ? <span>#{tags.slice(0, 3).join(' #')}{tags.length > 3 ? '…' : ''}</span> : null}
    </div>
  </div>
</article>
