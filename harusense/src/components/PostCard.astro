---
const { post, variant = 'default' } = Astro.props;
const { data } = post;
const href = `/posts/${post.slug}/`;
const cover = data.coverImage ?? '/images/post-placeholder.webp';
const excerpt = data.description ?? post.body?.slice?.(0, 140);
const classes = ['card'];
if (variant === 'square') classes.push('square');
---
<article class={classes.join(' ')}>
  <a class="thumb" href={href} aria-label={data.title}>
    <img src={cover} alt="" loading="lazy" />
  </a>
  <div class="inner">
    <h3><a href={href} style="text-decoration:none;">{data.title}</a></h3>
    <p>{excerpt}</p>
    <div class="meta">
      <span>{data.date.toLocaleDateString('ko-KR')}</span>
      {data.tags?.length ? <span>#{data.tags.join(' #')}</span> : null}
    </div>
  </div>
</article>
