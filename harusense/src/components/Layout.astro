---
const { title } = Astro.props
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="logo" href="/">HaruSense</a>
        <nav>
          <a href="/">Home</a>
          <a href="/category/lifehacks">생활꿀팁</a>
          <a href="/category/saving">절약·금융</a>
          <a href="/about">About</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} HaruSense — 하루센스</p>
        <nav>
          <a href="/privacy">Privacy</a>
          <a href="/ads">Ads</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
