---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allNews = await getCollection('canadaNews');

const today = new Date();
const visiblePosts = allPosts.filter((p) => p.data.date.getTime() <= today.getTime());

const sorted = visiblePosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const posts = sorted.slice(0, 8);

const groups = {
  canadaNews: allNews.sort((a,b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 6),
  japan: sorted.filter((p) => p.data.tags?.includes('japan') || p.data.tags?.includes('travel')).slice(0, 8),
  life: sorted.filter((p) => ['saving','budgeting','organization','routine','kitchen','consumption'].some((t) => p.data.tags?.includes(t))).slice(0, 8),
  english: sorted.filter((p) => p.data.tags?.includes('english')).slice(0, 8),
  japanese: sorted.filter((p) => p.data.tags?.includes('japanese')).slice(0, 8),
};

const featuredSlugs = [
  '2026-02-25-morning-routine',
  '2026-02-25-saving-checklist',
  '2026-02-26-home-cleaning',
  '2026-02-26-smart-shopping',
];

const featured = visiblePosts
  .filter((p) => featuredSlugs.includes(p.slug))
  .sort((a, b) => featuredSlugs.indexOf(a.slug) - featuredSlugs.indexOf(b.slug));
---
<BaseLayout>
  <section class="hero">
    <div class="container">
      <h1>오늘도, 쓸모 있는 한 가지</h1
      <p>
        PadoHaru는 ‘생활이 실제로 쉬워지는’ 팁만 모읍니다.
        루틴·절약·정리·구매·집안일을 더 똑똑하게.
      </p>
      <div class="cta">
        <a class="button primary" href="/posts">최신 글 보러가기</a>
        <a class="button" href="/about">소개</a>
      </div>
    </div>
  </section>

  {featured.length ? (
    <section>
      <div class="container">
        <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
          <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">추천 글(필독)</h2>
          <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
        </div>
        <div class="grid squares">
          {featured.map((post) => <PostCard post={post} variant="square" />)}
        </div>
      </div>
    </section>
  ) : null}

  <section>
    <div class="container">
      <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
        <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">최근 글</h2>
        <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
      </div>
      <div class="grid squares">
        {posts.map((post) => <PostCard post={post} variant="square" />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">카테고리별</h2>

      {groups.canadaNews.length ? (
        <div style="margin-top:14px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">캐나다뉴스</h3>
            <a href="/canada-news" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid">
            {groups.canadaNews.map((it) => (
              <article class="card" style="grid-column:span 6;">
                <div class="inner">
                  <h3 style="margin:0 0 8px;font-size:16px;">
                    <a href={`/canada-news/${it.slug}/`} style="text-decoration:none;">{it.data.title}</a>
                  </h3>
                  <p style="margin:0;color:var(--muted);font-size:13px;">{it.data.description}</p>
                  <div class="meta" style="margin-top:8px;">
                    <span>{it.data.date.toLocaleDateString('ko-KR')}</span>
                    {it.data.sourceUrl ? <span><a href={it.data.sourceUrl} target="_blank" rel="noreferrer" style="color:var(--muted);text-decoration:none;">원문</a></span> : null}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ) : null}

      {groups.japan.length ? (
        <div style="margin-top:6px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">일본/여행</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.japan.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

      {groups.life.length ? (
        <div style="margin-top:6px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">생활/절약/정리</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.life.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

      {groups.english.length ? (
        <div style="margin-top:6px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">오늘의 영어</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.english.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

      {groups.japanese.length ? (
        <div style="margin-top:6px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">오늘의 일본어</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.japanese.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

    </div>
  </section>
</BaseLayout>
