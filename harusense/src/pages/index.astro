---
import Layout from '../components/Layout.astro'
import PostCard from '../components/PostCard.astro'
import posts from '../../content/posts/index.js'
---

<Layout title="HaruSense — 하루센스">
  <section class="hero">
    <div class="hero-inner">
      <h1>매일 쓸모 있는 한 가지, 하루센스</h1>
      <p>생활을 더 편하게 만드는 실용 팁·절약 노하우·검증된 아이디어를 매일 제공합니다.</p>
      <div class="cta">
        <a class="btn primary" href="/category/lifehacks">오늘의 팁 보기</a>
        <a class="btn" href="/category/saving">카테고리 둘러보기</a>
      </div>
    </div>
    <div class="hero-image">
      <picture>
        <source type="image/webp" srcset="/images/hero-desktop.webp 1x, /images/hero-desktop@2x.webp 2x">
        <source srcset="/images/hero-desktop.jpg 1x, /images/hero-desktop@2x.jpg 2x">
        <img src="/images/hero-placeholder.jpg" alt="HaruSense hero" loading="lazy" />
      </picture>
    </div>
  </section>

  <section class="latest">
    <h2>최신 글</h2>
    <div class="post-grid">
      {posts.slice(0,6).map(post => (
        <PostCard post={post} />
      ))}
    </div>
  </section>

</Layout>
