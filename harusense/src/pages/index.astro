---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 8);

const featuredSlugs = [
  '2026-02-25-morning-routine',
  '2026-02-25-saving-checklist',
  '2026-02-26-home-cleaning',
  '2026-02-26-smart-shopping',
];

const featured = allPosts
  .filter((p) => featuredSlugs.includes(p.slug))
  .sort((a, b) => featuredSlugs.indexOf(a.slug) - featuredSlugs.indexOf(b.slug));
---
<BaseLayout>
  <section class="hero">
    <div class="container">
      <h1>오늘도, 쓸모 있는 한 가지.</h1>
      <p>
        HaruSense(하루센스)는 ‘생활이 실제로 쉬워지는’ 팁만 모읍니다.
        루틴·절약·정리·구매·집안일을 더 똑똑하게.
      </p>
      <div class="cta">
        <a class="button primary" href="/posts">최신 글 보러가기</a>
        <a class="button" href="/about">하루센스 소개</a>
      </div>
    </div>
  </section>

  {featured.length ? (
    <section>
      <div class="container">
        <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
          <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">추천 글(필독)</h2>
          <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
        </div>
        <div class="grid">
          {featured.map((post) => <PostCard post={post} />)}
        </div>
      </div>
    </section>
  ) : null}

  <section>
    <div class="container">
      <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
        <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">최근 글</h2>
        <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
      </div>
      <div class="grid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
