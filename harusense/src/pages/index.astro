---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allNews = await getCollection('canadaNews');

const today = new Date();
const visiblePosts = allPosts.filter((p) => p.data.date.getTime() <= today.getTime());
const sorted = visiblePosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const posts = sorted.slice(0, 8);

const groups = {
  canadaNews: allNews.sort((a,b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 4),
  life: sorted.filter((p) => ['saving','budgeting','organization','routine','kitchen','consumption','cleaning','home'].some((t) => p.data.tags?.includes(t))).slice(0, 8),
  canada: sorted.filter((p) => ['canada','korea','immigration','tips','money'].some((t) => p.data.tags?.includes(t))).slice(0, 6),
};

const featuredSlugs = [
  '2026-03-23-canada-e-transfer-scams',
  '2026-03-23-canada-rental-scams',
  '2026-03-11-counterfeit-banknotes-canada',
  '2026-03-16-korea-auto-entry-canadian-passport-guide',
];

const featured = visiblePosts
  .filter((p) => featuredSlugs.includes(p.slug))
  .sort((a, b) => featuredSlugs.indexOf(a.slug) - featuredSlugs.indexOf(b.slug));
---
<BaseLayout>
  <section class="hero">
    <div class="container">
      <h1>캐나다 실생활과 생활비 관리에 실제로 도움 되는 정보만 남겼습니다</h1>
      <p>
        PadoHaru는 캐나다 실생활 정보, 절약, 정리, 루틴, 주방 운영처럼
        바로 적용 가능한 주제만 선별해 정리합니다.
      </p>
      <div class="cta">
        <a class="button primary" href="/posts">대표 글 보러가기</a>
        <a class="button" href="/about">소개</a>
      </div>
    </div>
  </section>

  {featured.length ? (
    <section>
      <div class="container">
        <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
          <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">대표 글</h2>
          <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
        </div>
        <div class="grid squares">
          {featured.map((post) => <PostCard post={post} variant="square" />)}
        </div>
      </div>
    </section>
  ) : null}

  <section>
    <div class="container">
      <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
        <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">최근 업데이트</h2>
        <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
      </div>
      <div class="grid squares">
        {posts.map((post) => <PostCard post={post} variant="square" />)}
      </div>
    </div>
  </section>

  <section>
    <div class="container">
      <h2 style="margin:0;font-size:18px;color:var(--muted);font-weight:600;">주제별</h2>

      {groups.life.length ? (
        <div style="margin-top:14px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">절약·정리·루틴</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.life.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

      {groups.canada.length ? (
        <div style="margin-top:6px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">캐나다·한국 실생활 정보</h3>
            <a href="/posts" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid squares">
            {groups.canada.map((post) => <PostCard post={post} variant="square" />)}
          </div>
        </div>
      ) : null}

      {groups.canadaNews.length ? (
        <div style="margin-top:10px;">
          <div style="display:flex;align-items:end;justify-content:space-between;gap:12px;">
            <h3 style="margin:0;font-size:16px;">캐나다 뉴스 요약</h3>
            <a href="/canada-news" style="color:var(--muted);text-decoration:none;font-size:14px;">전체 보기 →</a>
          </div>
          <div class="grid">
            {groups.canadaNews.map((it) => (
              <article class="card" style="grid-column:span 6;">
                <div class="inner">
                  <h3 style="margin:0 0 8px;font-size:16px;">
                    <a href={`/canada-news#${it.slug}`} style="text-decoration:none;">{it.data.title}</a>
                  </h3>
                  <p style="margin:0;color:var(--muted);font-size:13px;">{it.data.description}</p>
                  <div class="meta" style="margin-top:8px;">
                    <span>{it.data.date.toLocaleDateString('ko-KR')}</span>
                    {it.data.sourceUrl ? <span><a href={it.data.sourceUrl} target="_blank" rel="noreferrer" style="color:var(--muted);text-decoration:none;">원문</a></span> : null}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
      ) : null}
    </div>
  </section>
</BaseLayout>
