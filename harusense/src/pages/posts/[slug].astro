---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const description = post.data.description ?? post.body.split('\n').find((l) => l.trim().length > 0)?.slice(0, 160);
const coverCredit = post.data.coverCredit;
const coverCreditUrl = post.data.coverCreditUrl;
---
<BaseLayout
  title={`${post.data.title} — PadoHaru`}
  description={description}
  image={post.data.coverImage ?? '/images/post-placeholder.webp'}
  canonical={`/posts/${post.slug}/`}
>
  <article class="article">
    <div class="container">
      <h1>{post.data.title}</h1>
      <div class="meta">
        <span>{post.data.date.toLocaleDateString('ko-KR')}</span>
        {post.data.tags?.length ? <span> · #{post.data.tags.join(' #')}</span> : null}
      </div>

      <div class="content">
        <Content />
      </div>

      {coverCredit ? (
        <div class="credit">
          이미지 출처: {coverCreditUrl ? <a href={coverCreditUrl} target="_blank" rel="noreferrer">{coverCredit}</a> : coverCredit}
        </div>
      ) : null}

      {headings?.length ? (
        <aside style="margin-top:28px;padding-top:18px;border-top:1px solid var(--border);color:var(--muted);font-size:14px;">
          <div style="font-weight:700;margin-bottom:8px;color:var(--text);">목차</div>
          <ul style="margin:0;padding-left:18px;">
            {headings.map((h) => (
              <li style="margin:6px 0;">
                <a href={`#${h.slug}`} style="color:var(--muted);text-decoration:none;">{h.text}</a>
              </li>
            ))}
          </ul>
        </aside>
      ) : null}

      <div style="margin-top:26px;display:flex;gap:12px;flex-wrap:wrap;">
        <a class="button" href="/posts">← 글 목록</a>
        <a class="button" href="/">홈</a>
      </div>
    </div>
  </article>
</BaseLayout>
