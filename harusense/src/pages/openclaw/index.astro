---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft && (data.tags ?? []).includes('openclaw')))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="OpenClaw 가이드 — PadoHaru" description="OpenClaw 설치, 초기 설정, 연결, 운영 팁을 초보자도 따라할 수 있게 정리한 카테고리입니다.">
  <section class="hero">
    <div class="container">
      <h1>OpenClaw 가이드</h1>
      <p>설치부터 연결, 운영까지. 초보자도 따라할 수 있게 차근차근 정리합니다.</p>
    </div>
  </section>

  <section>
    <div class="container">
      {posts.length ? (
        <div class="grid">
          {posts.map((post) => <PostCard post={post} />)}
        </div>
      ) : (
        <p style="color: var(--muted);">아직 공개된 OpenClaw 가이드 글이 없습니다.</p>
      )}
    </div>
  </section>
</BaseLayout>
