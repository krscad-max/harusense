---
import ThemeToggle from '../components/ThemeToggle.astro';

const {
  title = 'PadoHaru — 파도하루',
  description = '절약, 정리, 루틴, 주방, 캐나다 실생활 정보를 중심으로 바로 적용 가능한 글만 정리하는 실용 정보 사이트.',
  image = '/images/hero-desktop.webp',
  canonical,
} = Astro.props;

const site = Astro.site ?? 'https://harusense.example';
const url = canonical ? new URL(canonical, site) : Astro.url;
---
<!doctype html>
<html lang="ko" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url.toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url.toString()} />
    <meta property="og:image" content={new URL(image, site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles/global.css" />

    <!-- Google AdSense -->
    <meta name="google-adsense-account" content="ca-pub-9266812076678065" />
    <script
      async
      src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9266812076678065"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <header class="header">
      <div class="container">
        <nav class="nav">
          <a class="brand" href="/">
            <div>
              <b>PadoHaru</b>
              <small>절약, 정리, 루틴, 주방, 캐나다 실생활 정보</small>
            </div>
          </a>
          <div class="navlinks">
            <a href="/posts">블로그</a>
            <a href="/openclaw">OpenClaw 가이드</a>
            <a href="/canada-news">캐나다뉴스</a>
            <a href="/about">소개</a>
            <a href="/privacy">개인정보</a>
            <a href="/ads">광고/제휴</a>
          </div>
          <div style="display:flex;align-items:center;gap:10px;">
            <ThemeToggle />
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container">
        <div>© {new Date().getFullYear()} PadoHaru. 실생활에 바로 적용 가능한 정보만 정리합니다.</div>
      </div>
    </footer>
  </body>
</html>
